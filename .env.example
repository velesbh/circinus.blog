# REQUIRED: Admin dashboard access secret
ADMIN_SECRET=change_this_to_a_long_random_secret_string

# REQUIRED: Adsterra placement IDs (get from Adsterra publisher dashboard)
NEXT_PUBLIC_ADSTERRA_POPUNDER=your_popunder_placement_id
NEXT_PUBLIC_ADSTERRA_BANNER=your_banner_728x90_placement_id
NEXT_PUBLIC_ADSTERRA_RECTANGLE=your_rectangle_300x250_placement_id
NEXT_PUBLIC_ADSTERRA_LEADERBOARD=your_leaderboard_970x90_placement_id

# OPTIONAL
NEXT_PUBLIC_ADSTERRA_VERIFY=your_adsterra_site_verification_token
NEXT_PUBLIC_NEWSLETTER_URL=https://your-newsletter-service.com/subscribe
